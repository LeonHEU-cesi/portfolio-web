---
import { useTranslations } from '~/i18n/utils';
import { site } from '~/data/site';
import type { Lang } from '~/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div class="mx-auto grid max-w-6xl gap-6 px-6 py-12 sm:grid-cols-2 sm:items-center">
    <p class="text-sm text-muted">
      © {year} {site.name}. {t('footer_made_with')}
    </p>
    <ul class="flex flex-wrap gap-4 text-sm sm:justify-end">
      <li><a href={`mailto:${site.email}`} class="text-muted transition-colors hover:text-text">{t('contact_email_label')}</a></li>
      <li><a href={site.social.github} rel="me noopener" class="text-muted transition-colors hover:text-text">{t('contact_github_label')}</a></li>
      <li><a href={site.social.linkedin} rel="me noopener" class="text-muted transition-colors hover:text-text">{t('contact_linkedin_label')}</a></li>
    </ul>
  </div>
</footer>
