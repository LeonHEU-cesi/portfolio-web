---
import { useTranslations, useTranslatedPath } from '~/i18n/utils';
import { site } from '~/data/site';
import type { Lang } from '~/i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Lang;
  alternateLangUrl?: string;
}

const { lang, alternateLangUrl } = Astro.props;
const t = useTranslations(lang);
const p = useTranslatedPath(lang);

const navItems = [
  { href: p('home'), label: t('nav_home') },
  { href: p('about'), label: t('nav_about') },
  { href: p('projects'), label: t('nav_projects') },
  { href: p('blog'), label: t('nav_blog') },
  { href: p('contact'), label: t('nav_contact') },
];

const brand = site.name.toLowerCase().replace(/\s+/g, '.');
---

<header class="sticky top-0 z-20 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-3 px-6 sm:gap-6">
    <a
      href={p('home')}
      class="font-mono text-sm font-semibold tracking-tight text-text transition-opacity duration-200 ease-out hover:opacity-70"
    >
      {brand}
    </a>
    <nav aria-label="Primary" class="hidden items-center gap-8 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm text-muted transition-colors duration-200 ease-out hover:text-text">
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <LanguageSwitcher {lang} alternateUrl={alternateLangUrl} />
      <ThemeToggle {lang} />
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label={t('menu_label')}
        class="group inline-flex h-9 w-9 items-center justify-center rounded border border-border text-muted transition-colors duration-200 ease-out hover:text-text hover:border-text md:hidden"
      >
        <svg class="h-4 w-4 group-aria-expanded:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="hidden h-4 w-4 group-aria-expanded:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>
  <nav
    id="mobile-menu"
    aria-label="Mobile"
    hidden
    class="border-t border-border bg-bg md:hidden"
  >
    <ul class="mx-auto flex max-w-6xl flex-col px-6 py-2">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block border-b border-border py-4 text-sm text-text transition-colors duration-200 ease-out last:border-b-0 hover:text-accent"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
