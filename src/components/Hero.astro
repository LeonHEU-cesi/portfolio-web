---
import { useTranslations, useTranslatedPath } from '~/i18n/utils';
import type { Lang } from '~/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const p = useTranslatedPath(lang);
---

<section class="px-6 pb-24 pt-20 sm:pb-32 sm:pt-32">
  <div class="mx-auto max-w-7xl">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">
      {t('home_hero_eyebrow')}
    </p>
    <h1 class="text-display mt-8 text-text">
      {t('home_hero_title')}
    </h1>
    <p class="mt-8 max-w-2xl text-lg text-muted sm:text-xl">
      {t('home_hero_subtitle')}
    </p>
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href={p('projects')}
        class="inline-flex h-12 items-center rounded border border-text bg-text px-6 text-sm font-medium text-bg transition-opacity duration-200 ease-out hover:opacity-90"
      >
        {t('cta_all_projects')}
      </a>
      <a
        href={p('contact')}
        class="inline-flex h-12 items-center rounded border border-border px-6 text-sm font-medium text-text transition-colors duration-200 ease-out hover:border-text"
      >
        {t('cta_contact')}
      </a>
    </div>
  </div>
</section>
