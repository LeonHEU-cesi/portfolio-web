---
import type { CollectionEntry } from 'astro:content';
import { useTranslatedPath } from '~/i18n/utils';
import type { Lang } from '~/i18n/ui';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}

const { post, lang } = Astro.props;
const p = useTranslatedPath(lang);
const slug = post.id.replace(/^(fr|en)\//, '');
const href = p('blog', slug);

const dateFormatter = new Intl.DateTimeFormat(lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group rounded border border-border bg-surface p-6 transition-all hover:-translate-y-0.5 hover:border-text">
  <a href={href} class="block">
    <time datetime={post.data.pubDate.toISOString()} class="font-mono text-xs text-muted">
      {dateFormatter.format(post.data.pubDate)}
    </time>
    <h3 class="mt-2 text-lg font-semibold tracking-tight text-text">{post.data.title}</h3>
    <p class="mt-2 text-sm text-muted">{post.data.description}</p>
  </a>
</article>
