---
import type { SkillGroup } from '~/data/skills';
import type { Lang } from '~/i18n/ui';

interface Props {
  group: SkillGroup;
  lang: Lang;
}

const { group, lang } = Astro.props;
const label = lang === 'fr' ? group.label_fr : group.label_en;
---

<div>
  <h3 class="font-mono text-xs uppercase tracking-widest text-muted">{label}</h3>
  <ul class="mt-3 flex flex-wrap gap-2">
    {group.skills.map((skill) => (
      <li class="rounded border border-border bg-surface px-3 py-1 text-sm text-text">{skill}</li>
    ))}
  </ul>
</div>
