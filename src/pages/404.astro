---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);
---

<BaseLayout title={`404 — ${t('not_found_title')}`} description={t('not_found_title')} {lang}>
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">/404</p>
    <h1 class="text-display-sm mt-6 text-balance text-text">
      {t('not_found_title')}
    </h1>
    <a
      href="/"
      class="mt-12 inline-flex h-11 items-center rounded border border-text bg-text px-5 text-sm font-medium text-bg transition-opacity duration-200 ease-out hover:opacity-90"
    >
      ← {t('not_found_back_home')}
    </a>
  </section>
</BaseLayout>
