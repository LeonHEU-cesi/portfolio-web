---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);
---

<BaseLayout title={`404 — ${t('not_found_title')}`} description={t('not_found_title')} {lang}>
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="font-mono text-sm text-accent">404</p>
    <h1 class="mt-4 text-balance text-4xl font-bold tracking-tight text-text sm:text-5xl">
      {t('not_found_title')}
    </h1>
    <a href="/" class="mt-8 inline-flex h-10 items-center rounded border border-text bg-text px-5 text-sm font-medium text-bg transition-opacity hover:opacity-80">
      ← {t('not_found_back_home')}
    </a>
  </section>
</BaseLayout>
