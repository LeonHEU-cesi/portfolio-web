---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SkillGroup from '~/components/SkillGroup.astro';
import { useTranslations } from '~/i18n/utils';
import { skillGroups } from '~/data/skills';
import { experiences } from '~/data/experiences';

const lang = 'fr';
const t = useTranslations(lang);

const dateFormatter = new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'short' });
function fmt(iso: string | null) {
  if (!iso) return t('today');
  const [y, m] = iso.split('-').map(Number);
  return dateFormatter.format(new Date(y, m - 1, 1));
}
---

<BaseLayout
  title={`${t('about_title')} — Léon Heu`}
  description={t('about_description')}
  {lang}
  alternateLangUrl="/en/about"
>
  <section class="mx-auto max-w-4xl px-6 py-20 sm:py-28">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">/{t('nav_about').toLowerCase()}</p>
    <h1 class="text-display-sm mt-6 text-balance text-text">
      {t('about_intro_title')}
    </h1>
    <p class="mt-8 max-w-2xl text-lg text-muted sm:text-xl">{t('about_intro_body')}</p>

    <section class="mt-24">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">/{t('about_experience_title').toLowerCase()}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-text sm:text-4xl">
        {t('about_experience_title')}
      </h2>
      <ol class="mt-10 space-y-4">
        {experiences.map((exp) => (
          <li class="rounded-md border border-border bg-surface p-6 transition-colors duration-200 ease-out hover:border-text">
            <p class="font-mono text-xs uppercase tracking-widest text-muted">
              {fmt(exp.startDate)} → {fmt(exp.endDate)}
            </p>
            <h3 class="mt-3 text-lg font-semibold tracking-tight text-text">{exp.title_fr}</h3>
            <p class="mt-1 text-sm text-muted">{exp.org}</p>
            <p class="mt-3 text-sm text-text">{exp.summary_fr}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="mt-24">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">/{t('about_skills_title').toLowerCase()}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-text sm:text-4xl">
        {t('about_skills_title')}
      </h2>
      <div class="mt-10 grid gap-10 sm:grid-cols-2">
        {skillGroups.map((group) => <SkillGroup {group} {lang} />)}
      </div>
    </section>
  </section>
</BaseLayout>
