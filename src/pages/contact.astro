---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/utils';
import { site } from '~/data/site';

const lang = 'fr';
const t = useTranslations(lang);

const links = [
  { label: t('contact_email_label'), value: site.email, href: `mailto:${site.email}` },
  { label: t('contact_github_label'), value: site.social.github.replace('https://', ''), href: site.social.github, external: true },
  { label: t('contact_linkedin_label'), value: site.social.linkedin.replace('https://', ''), href: site.social.linkedin, external: true },
  { label: t('contact_cv_label'), value: t('cta_download_cv'), href: site.cv.fr, download: true },
];
---

<BaseLayout
  title={`${t('contact_title')} — Léon Heu`}
  description={t('contact_description')}
  {lang}
  alternateLangUrl="/en/contact"
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="font-mono text-xs uppercase tracking-widest text-accent">/{t('nav_contact').toLowerCase()}</p>
    <h1 class="mt-4 text-balance text-4xl font-bold tracking-tight text-text sm:text-5xl">{t('contact_title')}</h1>
    <p class="mt-4 text-lg text-muted">{t('contact_intro')}</p>

    <ul class="mt-12 space-y-2 font-mono text-sm">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            rel={link.external ? 'me noopener' : undefined}
            download={link.download ? '' : undefined}
            class="flex items-center justify-between rounded border border-border bg-surface px-5 py-4 transition-colors hover:border-text"
          >
            <span class="text-muted">{link.label.toUpperCase()}</span>
            <span class="text-text">{link.value} →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
