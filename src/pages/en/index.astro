---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { useTranslations, useTranslatedPath } from '~/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const p = useTranslatedPath(lang);

const projects = await getCollection('projects');
const featured = projects
  .filter((pr) => pr.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={t('home_title')}
  description={t('home_description')}
  {lang}
  alternateLangUrl="/"
>
  <Hero {lang} />

  <section class="px-6 pb-24">
    <div class="mx-auto max-w-6xl">
      <header class="mb-8 flex items-end justify-between gap-6">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-text sm:text-3xl">
            {t('home_featured_title')}
          </h2>
          <p class="mt-2 text-muted">{t('home_featured_subtitle')}</p>
        </div>
        <a href={p('projects')} class="hidden font-mono text-xs uppercase tracking-widest text-muted transition-colors hover:text-text sm:inline-block">
          {t('cta_all_projects')} →
        </a>
      </header>
      <div class="grid gap-4 sm:grid-cols-2">
        {featured.map((project) => <ProjectCard {project} {lang} />)}
      </div>
    </div>
  </section>
</BaseLayout>
