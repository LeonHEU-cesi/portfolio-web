---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { useTranslations, useTranslatedPath } from '~/i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);
const p = useTranslatedPath(lang);

const projects = await getCollection('projects');
const featured = projects
  .filter((pr) => pr.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={t('home_title')}
  description={t('home_description')}
  {lang}
  alternateLangUrl="/en/"
>
  <Hero {lang} />

  <section class="px-6 pb-28">
    <div class="mx-auto max-w-6xl">
      <header class="mb-10 flex items-end justify-between gap-6 border-t border-border pt-10">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">/featured</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-text sm:text-4xl">
            {t('home_featured_title')}
          </h2>
          <p class="mt-3 text-muted">{t('home_featured_subtitle')}</p>
        </div>
        <a
          href={p('projects')}
          class="hidden font-mono text-xs uppercase tracking-widest text-muted transition-colors duration-200 ease-out hover:text-text sm:inline-block"
        >
          {t('cta_all_projects')} →
        </a>
      </header>
      <div class="grid gap-4 sm:grid-cols-2">
        {featured.map((project) => <ProjectCard {project} {lang} />)}
      </div>
    </div>
  </section>
</BaseLayout>
